# 异步编程规范

## Async/Await 基础

### 定义异步函数

```python
import asyncio
from typing import List, Dict, Any

async def fetch_data(item_id: str) -> dict:
    """
    异步获取数据
    
    Args:
        item_id: 项目ID
        
    Returns:
        数据字典
    """
    # 模拟异步 I/O 操作
    await asyncio.sleep(0.1)
    return {"id": item_id, "data": "..."}

async def process_item(item: dict) -> dict:
    """异步处理单个项目"""
    await asyncio.sleep(0.05)
    return {"processed": True, **item}
```

### 调用异步函数

```python
# ✅ 正确：在异步函数中使用 await
async def main():
    result = await fetch_data("123")
    processed = await process_item(result)
    return processed

# ❌ 错误：忘记使用 await
async def wrong_main():
    result = fetch_data("123")  # 返回 coroutine 对象，不是结果！
    return result
```

## 并发执行

### 使用 asyncio.gather

```python
async def process_batch_concurrent(items: List[str]) -> List[dict]:
    """
    并发处理多个项目
    
    所有任务同时开始执行，等待全部完成
    """
    tasks = [fetch_data(item_id) for item_id in items]
    results = await asyncio.gather(*tasks)
    return results

# 处理异常
async def process_batch_with_error_handling(items: List[str]) -> List[dict]:
    """并发处理，返回异常而不是抛出"""
    tasks = [fetch_data(item_id) for item_id in items]
    # return_exceptions=True 会将异常作为结果返回
    results = await asyncio.gather(*tasks, return_exceptions=True)
    
    # 过滤出成功的结果
    successful_results = [
        r for r in results 
        if not isinstance(r, Exception)
    ]
    
    # 记录失败的任务
    failures = [
        r for r in results 
        if isinstance(r, Exception)
    ]
    for error in failures:
        logger.error(f"任务失败: {str(error)}")
    
    return successful_results
```

### 使用 asyncio.create_task

```python
async def concurrent_operations():
    """同时启动多个独立任务"""
    # 创建任务（立即开始执行）
    task1 = asyncio.create_task(fetch_data("1"))
    task2 = asyncio.create_task(fetch_data("2"))
    task3 = asyncio.create_task(process_item({"id": "3"}))
    
    # 做其他事情...
    await asyncio.sleep(0.01)
    
    # 等待所有任务完成
    result1 = await task1
    result2 = await task2
    result3 = await task3
    
    return [result1, result2, result3]
```

### 使用 asyncio.as_completed

```python
async def process_as_completed(items: List[str]):
    """按完成顺序处理结果"""
    tasks = [fetch_data(item_id) for item_id in items]
    
    for coro in asyncio.as_completed(tasks):
        result = await coro
        # 一旦有任务完成就立即处理
        logger.info(f"处理完成: {result['id']}")
        yield result
```

## 异步上下文管理

### 定义异步上下文管理器

```python
class AsyncDatabaseConnection:
    """异步数据库连接上下文管理器"""
    
    def __init__(self, connection_string: str):
        self.connection_string = connection_string
        self.connection = None
    
    async def __aenter__(self):
        """进入上下文时打开连接"""
        logger.info("打开数据库连接")
        await asyncio.sleep(0.1)  # 模拟连接
        self.connection = {"connected": True}
        return self.connection
    
    async def __aexit__(self, exc_type, exc_val, exc_tb):
        """退出上下文时关闭连接"""
        logger.info("关闭数据库连接")
        await asyncio.sleep(0.05)  # 模拟关闭
        self.connection = None

# 使用
async def query_database():
    async with AsyncDatabaseConnection("connection_string") as conn:
        # 使用连接
        result = await perform_query(conn)
        return result
    # 退出上下文时自动关闭连接
```

## 异步迭代器

### 定义异步迭代器

```python
class AsyncDataStream:
    """异步数据流迭代器"""
    
    def __init__(self, count: int):
        self.count = count
        self.current = 0
    
    def __aiter__(self):
        return self
    
    async def __anext__(self):
        if self.current >= self.count:
            raise StopAsyncIteration
        
        # 模拟异步获取数据
        await asyncio.sleep(0.1)
        self.current += 1
        return f"data-{self.current}"

# 使用
async def process_stream():
    async for data in AsyncDataStream(5):
        logger.info(f"处理数据: {data}")
```

## 超时控制

### 使用 asyncio.wait_for

```python
async def fetch_with_timeout(url: str, timeout: float = 5.0) -> dict:
    """
    带超时的异步请求
    
    Args:
        url: 请求 URL
        timeout: 超时时间（秒）
        
    Returns:
        响应数据
        
    Raises:
        asyncio.TimeoutError: 超时时
    """
    try:
        result = await asyncio.wait_for(
            fetch_data_from_url(url),
            timeout=timeout
        )
        return result
    except asyncio.TimeoutError:
        logger.error(f"请求超时: {url}")
        raise

# 使用多个超时
async def complex_operation():
    """复杂操作with多个超时"""
    try:
        # 第一步：5秒超时
        step1 = await asyncio.wait_for(
            first_step(),
            timeout=5.0
        )
        
        # 第二步：10秒超时
        step2 = await asyncio.wait_for(
            second_step(step1),
            timeout=10.0
        )
        
        return step2
    except asyncio.TimeoutError as e:
        logger.error("操作超时")
        raise
```

## 信号量和限流

### 使用 asyncio.Semaphore

```python
class RateLimitedClient:
    """限流客户端"""
    
    def __init__(self, max_concurrent: int = 5):
        """
        Args:
            max_concurrent: 最大并发数
        """
        self.semaphore = asyncio.Semaphore(max_concurrent)
    
    async def fetch(self, url: str) -> dict:
        """限流的异步请求"""
        async with self.semaphore:
            logger.debug(f"开始请求: {url}")
            result = await self._do_fetch(url)
            logger.debug(f"完成请求: {url}")
            return result
    
    async def _do_fetch(self, url: str) -> dict:
        """实际的请求逻辑"""
        await asyncio.sleep(0.1)
        return {"url": url, "data": "..."}

# 使用
async def fetch_many_urls(urls: List[str]):
    """批量请求（最多5个并发）"""
    client = RateLimitedClient(max_concurrent=5)
    tasks = [client.fetch(url) for url in urls]
    results = await asyncio.gather(*tasks)
    return results
```

## 异步错误处理

### 捕获和处理异步异常

```python
async def safe_async_operation():
    """安全的异步操作（包含错误处理）"""
    try:
        result = await risky_async_operation()
        return result
    except asyncio.CancelledError:
        # 任务被取消
        logger.warning("任务被取消")
        raise  # 重新抛出 CancelledError
    except asyncio.TimeoutError:
        # 超时
        logger.error("操作超时")
        return {"error": "timeout"}
    except Exception as e:
        # 其他异常
        logger.error(f"操作失败: {str(e)}", exc_info=True)
        return {"error": str(e)}
```

### 任务取消

```python
async def cancellable_operation():
    """可取消的长时间运行操作"""
    try:
        for i in range(100):
            # 定期检查是否被取消
            await asyncio.sleep(0.1)
            logger.debug(f"进度: {i}/100")
    except asyncio.CancelledError:
        logger.info("操作被取消，正在清理...")
        # 执行清理逻辑
        await cleanup()
        raise  # 重新抛出以完成取消

# 使用
async def main():
    task = asyncio.create_task(cancellable_operation())
    
    # 等待一段时间后取消
    await asyncio.sleep(1.0)
    task.cancel()
    
    try:
        await task
    except asyncio.CancelledError:
        logger.info("任务已取消")
```

## 性能优化

### 避免阻塞操作

```python
import asyncio
from concurrent.futures import ThreadPoolExecutor

executor = ThreadPoolExecutor(max_workers=4)

async def run_blocking_operation(data: dict) -> dict:
    """
    在线程池中运行阻塞操作
    
    用于不支持异步的库或 CPU 密集型操作
    """
    loop = asyncio.get_event_loop()
    
    # 在线程池中运行阻塞函数
    result = await loop.run_in_executor(
        executor,
        blocking_function,  # 阻塞函数
        data  # 参数
    )
    
    return result

def blocking_function(data: dict) -> dict:
    """CPU 密集型或阻塞的同步函数"""
    import time
    time.sleep(1)  # 阻塞操作
    return {"processed": True}
```

## 最佳实践

### ✅ 应该做的

```python
# 1. 优先使用异步库
import httpx  # ✅ 异步 HTTP 库
async with httpx.AsyncClient() as client:
    response = await client.get(url)

# 2. 批量并发处理
async def process_all(items: List[str]):
    tasks = [process_item(item) for item in items]
    return await asyncio.gather(*tasks)

# 3. 使用异步上下文管理器
async with AsyncResource() as resource:
    await resource.use()

# 4. 设置合理的超时
result = await asyncio.wait_for(operation(), timeout=30.0)

# 5. 正确处理 CancelledError
try:
    await long_running_task()
except asyncio.CancelledError:
    await cleanup()
    raise
```

### ❌ 不应该做的

```python
# 1. 在异步函数中使用阻塞调用
async def bad_function():
    import time
    time.sleep(5)  # ❌ 阻塞整个事件循环！

# 2. 串行执行可以并发的操作
async def slow_processing(items):
    results = []
    for item in items:
        result = await process(item)  # ❌ 逐个等待
        results.append(result)
    return results

# 3. 忘记 await
async def forgot_await():
    result = fetch_data()  # ❌ 返回 coroutine，不是结果
    return result

# 4. 在循环中创建过多任务
async def too_many_tasks(items):
    # ❌ 可能创建成千上万个并发任务
    tasks = [process(item) for item in items]
    return await asyncio.gather(*tasks)
```

### 批量处理大量任务

```python
async def process_in_batches(
    items: List[str],
    batch_size: int = 10
) -> List[dict]:
    """
    分批并发处理大量任务
    
    Args:
        items: 待处理项目列表
        batch_size: 每批处理数量
        
    Returns:
        所有结果
    """
    results = []
    
    for i in range(0, len(items), batch_size):
        batch = items[i:i + batch_size]
        logger.info(f"处理批次 {i//batch_size + 1}，包含 {len(batch)} 个项目")
        
        # 并发处理当前批次
        batch_results = await asyncio.gather(
            *[process_item(item) for item in batch],
            return_exceptions=True
        )
        
        results.extend(batch_results)
    
    return results
```

