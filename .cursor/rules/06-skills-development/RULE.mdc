## 技能测试规范

```python
# tests/test_skill_name.py
import pytest
from skills.library.skill_name.scripts.main import execute, validate_params

class TestSkillName:
    """技能测试类"""
    
    async def test_execute_success(self):
        """测试成功执行"""
        params = {"param1": "test_value"}
        result = await execute(params)
        
        assert result["success"] is True
        assert "result" in result
    
    async def test_execute_missing_param(self):
        """测试缺少必需参数"""
        params = {}
        result = await execute(params)
        
        assert result["success"] is False
        assert "error" in result
    
    def test_validate_params_success(self):
        """测试参数验证成功"""
        params = {"param1": "test"}
        validate_params(params)  # 不应抛出异常
    
    def test_validate_params_failure(self):
        """测试参数验证失败"""
        params = {}
        with pytest.raises(ValueError):
            validate_params(params)
```

## 技能集成规范

```python
# skills/__init__.py
from pathlib import Path
from typing import Dict, List
import importlib

def discover_skills() -> List[str]:
    """发现所有可用技能"""
    skills_dir = Path(__file__).parent / "library"
    skills = []
    
    for skill_path in skills_dir.iterdir():
        if skill_path.is_dir() and (skill_path / "SKILL.md").exists():
            skills.append(skill_path.name)
    
    return skills

async def execute_skill(skill_name: str, params: Dict) -> Dict:
    """执行指定技能"""
    module_path = f"skills.library.{skill_name}.scripts.main"
    module = importlib.import_module(module_path)
    return await module.execute(params)
```

## 系统提示词注入

Skill 的元数据（name, description, priority, preferred_for）会自动注入到系统提示词中，
帮助 Claude 了解可用的工作流技能。这与 Claude Skills 完全独立。

```python
# 加载 Skills 元数据到系统提示词
from prompts.skills_loader import load_skills_for_system_prompt

skills_section = load_skills_for_system_prompt("skills/library")
system_prompt = BASE_PROMPT + "\n\n" + skills_section
```
