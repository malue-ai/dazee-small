## 脚本开发规范

### 主执行脚本结构

```python
"""
技能脚本说明

详细描述此脚本的功能和使用方法
"""

import logging
from typing import Dict, Any, Optional
from pathlib import Path

logger = logging.getLogger(__name__)

# 脚本元数据
SKILL_NAME = "skill_name"
SKILL_VERSION = "1.0.0"

async def execute(params: Dict[str, Any]) -> Dict[str, Any]:
    """
    执行技能逻辑
    
    Args:
        params: 输入参数字典
            - param1 (str): 参数1说明
            - param2 (int, optional): 参数2说明
            
    Returns:
        执行结果字典：
        {
            "success": bool,
            "result": Any,
            "message": str,
            "error": str (仅失败时)
        }
        
    Raises:
        ValueError: 参数验证失败时
    """
    try:
        # 1. 验证参数
        validate_params(params)
        
        # 2. 执行核心逻辑
        result = await perform_task(params)
        
        # 3. 返回结果
        return {
            "success": True,
            "result": result,
            "message": "执行成功"
        }
        
    except ValueError as e:
        logger.error(f"参数验证失败: {str(e)}")
        return {
            "success": False,
            "error": str(e),
            "message": "参数验证失败"
        }
    except Exception as e:
        logger.error(f"技能执行失败: {str(e)}", exc_info=True)
        return {
            "success": False,
            "error": str(e),
            "message": "执行失败"
        }


def validate_params(params: Dict[str, Any]) -> None:
    """
    验证输入参数
    
    Args:
        params: 输入参数字典
        
    Raises:
        ValueError: 参数验证失败时
    """
    if 'param1' not in params:
        raise ValueError("缺少必需参数: param1")
    
    if not isinstance(params['param1'], str):
        raise ValueError("param1 必须是字符串类型")


async def perform_task(params: Dict[str, Any]) -> Any:
    """
    执行核心任务
    
    Args:
        params: 输入参数字典
        
    Returns:
        任务执行结果
    """
    logger.info(f"开始执行技能: {SKILL_NAME}")
    
    # 实现核心逻辑
    result = {}
    
    logger.info(f"技能执行完成: {SKILL_NAME}")
    return result


def load_resource(filename: str) -> Any:
    """
    加载资源文件
    
    Args:
        filename: 资源文件名
        
    Returns:
        资源内容
    """
    resource_path = Path(__file__).parent.parent / "resources" / filename
    
    if not resource_path.exists():
        raise FileNotFoundError(f"资源文件不存在: {filename}")
    
    with open(resource_path, 'r', encoding='utf-8') as f:
        return f.read()


# 如果直接运行此脚本
if __name__ == "__main__":
    import asyncio
    
    test_params = {"param1": "test_value"}
    result = asyncio.run(execute(test_params))
    print(f"执行结果: {result}")
```

