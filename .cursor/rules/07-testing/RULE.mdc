# 测试开发规范

## 测试文件组织

```
tests/
├── __init__.py
├── conftest.py              # 共享 fixtures
├── test_routers/            # 路由测试
│   ├── test_chat.py
│   └── test_knowledge.py
├── test_core/               # 核心模块测试
│   ├── test_agent.py
│   └── test_memory.py
├── test_tools/              # 工具测试
│   └── test_api_calling.py
└── integration/             # 集成测试
    └── test_full_workflow.py
```

## 测试命名规范

- 测试文件：`test_<module_name>.py`
- 测试类：`Test<FeatureName>`
- 测试函数：`test_<scenario>_<expected_result>`

```python
# ✅ 良好的命名
def test_create_user_with_valid_data_returns_success():
    pass

def test_create_user_with_duplicate_email_raises_error():
    pass

# ❌ 不好的命名
def test_1():
    pass

def test_user():
    pass
```

## 测试结构（AAA 模式）

使用 Arrange-Act-Assert 模式：

```python
import pytest
from unittest.mock import Mock, patch, AsyncMock

class TestChatRouter:
    """聊天路由测试类"""
    
    async def test_send_message_with_valid_input_returns_response(self):
        """测试发送有效消息返回响应"""
        # Arrange（准备）
        message = "你好"
        expected_response = "你好！有什么可以帮助你的吗？"
        
        mock_agent = AsyncMock()
        mock_agent.process_message.return_value = {
            "response": expected_response
        }
        
        # Act（执行）
        result = await chat_handler(message, agent=mock_agent)
        
        # Assert（断言）
        assert result["success"] is True
        assert result["response"] == expected_response
        mock_agent.process_message.assert_called_once_with(message)
```

## Fixtures 定义

使用 pytest fixtures 管理测试数据和依赖：

```python
# conftest.py
import pytest
from core.agent import Agent
from core.memory import Memory
from core.llm_service import LLMService

@pytest.fixture
def mock_llm_service():
    """Mock LLM 服务"""
    service = Mock(spec=LLMService)
    service.generate.return_value = "模拟响应"
    return service

@pytest.fixture
def mock_memory():
    """Mock 内存服务"""
    memory = Mock(spec=Memory)
    memory.get_messages.return_value = []
    return memory

@pytest.fixture
def agent(mock_llm_service, mock_memory):
    """创建 Agent 实例"""
    return Agent(
        llm_service=mock_llm_service,
        memory=mock_memory
    )

@pytest.fixture
def sample_messages():
    """示例消息列表"""
    return [
        {"role": "user", "content": "你好"},
        {"role": "assistant", "content": "你好！"}
    ]
```

## 异步测试

使用 pytest-asyncio 测试异步函数：

```python
import pytest

class TestAsyncOperations:
    """异步操作测试"""
    
    @pytest.mark.asyncio
    async def test_async_function_success(self):
        """测试异步函数成功执行"""
        result = await some_async_function()
        assert result is not None
    
    @pytest.mark.asyncio
    async def test_async_function_with_mock(self):
        """测试异步函数与 mock"""
        mock_service = AsyncMock()
        mock_service.fetch_data.return_value = {"data": "test"}
        
        result = await function_using_service(mock_service)
        
        assert result["data"] == "test"
        mock_service.fetch_data.assert_awaited_once()
```

## Mock 使用规范

### Mock 对象

```python
from unittest.mock import Mock, MagicMock

def test_with_mock():
    """使用 Mock 对象"""
    # 创建 mock
    mock_service = Mock()
    
    # 设置返回值
    mock_service.get_data.return_value = {"key": "value"}
    
    # 调用
    result = mock_service.get_data()
    
    # 验证调用
    assert result == {"key": "value"}
    mock_service.get_data.assert_called_once()
```

### Patch 装饰器

```python
from unittest.mock import patch

class TestWithPatch:
    """使用 patch 测试"""
    
    @patch('module.external_api_call')
    def test_function_calls_external_api(self, mock_api):
        """测试函数调用外部 API"""
        mock_api.return_value = {"status": "ok"}
        
        result = function_that_calls_api()
        
        assert result["status"] == "ok"
        mock_api.assert_called_once()
    
    @patch('module.Service')
    def test_function_with_class_patch(self, MockService):
        """测试类的 patch"""
        mock_instance = MockService.return_value
        mock_instance.method.return_value = "mocked"
        
        result = function_using_service()
        
        assert result == "mocked"
```

### AsyncMock

```python
from unittest.mock import AsyncMock

async def test_async_with_mock():
    """测试异步函数与 AsyncMock"""
    mock_service = AsyncMock()
    mock_service.async_method.return_value = "async result"
    
    result = await function_using_async_service(mock_service)
    
    assert result == "async result"
    mock_service.async_method.assert_awaited_once()
```

## 异常测试

```python
import pytest

class TestExceptions:
    """异常测试"""
    
    def test_function_raises_value_error(self):
        """测试函数抛出 ValueError"""
        with pytest.raises(ValueError) as exc_info:
            function_that_raises_error()
        
        assert "预期的错误信息" in str(exc_info.value)
    
    def test_function_raises_custom_error(self):
        """测试自定义异常"""
        with pytest.raises(CustomError) as exc_info:
            function_that_raises_custom_error()
        
        assert exc_info.value.code == "ERROR_CODE"
    
    async def test_async_function_raises_error(self):
        """测试异步函数抛出异常"""
        with pytest.raises(RuntimeError):
            await async_function_that_raises()
```

## 参数化测试

```python
import pytest

class TestParametrized:
    """参数化测试"""
    
    @pytest.mark.parametrize("input_value,expected", [
        ("test", "TEST"),
        ("hello", "HELLO"),
        ("", ""),
    ])
    def test_uppercase_conversion(self, input_value, expected):
        """测试大写转换"""
        result = convert_to_uppercase(input_value)
        assert result == expected
    
    @pytest.mark.parametrize("age,valid", [
        (0, True),
        (18, True),
        (150, True),
        (-1, False),
        (151, False),
    ])
    def test_age_validation(self, age, valid):
        """测试年龄验证"""
        if valid:
            validate_age(age)  # 不应抛出异常
        else:
            with pytest.raises(ValueError):
                validate_age(age)
```

## 测试覆盖率

### 运行测试覆盖率

```bash
# 运行测试并生成覆盖率报告
pytest --cov=core --cov=tools --cov=routers --cov-report=html

# 查看覆盖率报告
open htmlcov/index.html
```

### 测试覆盖目标

- 核心业务逻辑：90%+
- 工具模块：80%+
- 路由层：70%+
- 测试重点：
  - 成功场景
  - 边界条件
  - 错误处理
  - 异常分支

