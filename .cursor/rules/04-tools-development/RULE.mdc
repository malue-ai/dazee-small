# Tools 工具模块开发规范

## 工具基类规范

所有工具必须继承 `BaseTool` 并实现 `execute` 方法：

```python
from tools.base import BaseTool
from typing import Dict, Any
import logging

class MyTool(BaseTool):
    """
    工具说明
    
    这里详细描述工具的功能和使用场景
    """
    
    name: str = "tool_name"
    description: str = "工具的详细描述，用于 LLM 理解何时使用此工具"
    
    def __init__(self):
        """初始化工具"""
        super().__init__()
        self.logger = logging.getLogger(__name__)
    
    async def execute(self, **kwargs) -> Dict[str, Any]:
        """
        执行工具逻辑
        
        Args:
            **kwargs: 工具参数
                - param1 (str): 参数1说明
                - param2 (int): 参数2说明
            
        Returns:
            包含执行结果的字典，格式：
            {
                "success": bool,
                "data": Any,
                "message": str,
                "error": str (仅失败时)
            }
            
        Raises:
            ValueError: 参数验证失败时
        """
        try:
            # 1. 参数验证
            self._validate_params(**kwargs)
            
            # 2. 执行核心逻辑
            result = await self._perform_action(**kwargs)
            
            # 3. 返回成功结果
            return {
                "success": True,
                "data": result,
                "message": "执行成功"
            }
            
        except ValueError as e:
            self.logger.error(f"参数验证失败: {str(e)}")
            return {
                "success": False,
                "error": str(e),
                "message": "参数验证失败"
            }
        except Exception as e:
            self.logger.error(f"工具执行失败: {str(e)}", exc_info=True)
            return {
                "success": False,
                "error": str(e),
                "message": "执行失败"
            }
    
    def _validate_params(self, **kwargs) -> None:
        """验证输入参数"""
        pass
    
    async def _perform_action(self, **kwargs) -> Any:
        """执行核心动作"""
        raise NotImplementedError
```

## 统一返回格式

所有工具必须返回以下格式：

```python
# 成功响应
{
    "success": True,      # 必需：表示执行是否成功
    "data": result,       # 成功时的数据
    "message": "执行成功"  # 可读的消息
}

# 失败响应
{
    "success": False,         # 必需：表示执行失败
    "error": "错误详情",       # 失败时的错误信息
    "message": "执行失败",     # 可读的消息
    "error_code": "ERR_CODE"  # 可选：错误代码
}
```

## 工具参数定义

使用清晰的参数定义和验证：

```python
class SearchTool(BaseTool):
    """搜索工具"""
    
    name: str = "web_search"
    description: str = """
    在互联网上搜索信息
    
    使用场景：
    - 需要获取最新信息时
    - 需要查找特定领域知识时
    - 需要验证事实时
    """
    
    def _validate_params(self, **kwargs) -> None:
        """验证参数"""
        query = kwargs.get('query')
        if not query:
            raise ValueError("缺少必需参数: query")
        
        if not isinstance(query, str):
            raise ValueError("query 必须是字符串类型")
        
        if len(query) < 2:
            raise ValueError("query 长度不能少于 2 个字符")
        
        max_results = kwargs.get('max_results', 10)
        if not isinstance(max_results, int) or max_results < 1:
            raise ValueError("max_results 必须是正整数")
```

## 工具注册和发现

工具应该可以被自动发现和注册：

```python
# tools/__init__.py
from tools.base import BaseTool
from tools.search_tool import SearchTool
from tools.calculator_tool import CalculatorTool

# 所有可用工具
AVAILABLE_TOOLS = [
    SearchTool,
    CalculatorTool,
]

def get_tool_by_name(name: str) -> BaseTool:
    """根据名称获取工具实例"""
    for tool_class in AVAILABLE_TOOLS:
        if tool_class.name == name:
            return tool_class()
    raise ValueError(f"未找到工具: {name}")
```

## 异步工具实现

优先使用异步实现以提高性能：

```python
class APICallingTool(BaseTool):
    """API 调用工具"""
    
    async def _perform_action(self, **kwargs) -> Any:
        """执行 API 调用"""
        import httpx
        
        url = kwargs['url']
        method = kwargs.get('method', 'GET')
        
        async with httpx.AsyncClient() as client:
            if method == 'GET':
                response = await client.get(url)
            elif method == 'POST':
                response = await client.post(url, json=kwargs.get('data'))
            
            return response.json()
```

## 工具测试规范

每个工具都应该有完整的测试：

```python
# tests/test_my_tool.py
import pytest
from tools.my_tool import MyTool

class TestMyTool:
    """MyTool 测试类"""
    
    @pytest.fixture
    def tool(self):
        """创建工具实例"""
        return MyTool()
    
    async def test_success_case(self, tool):
        """测试成功场景"""
        result = await tool.execute(param1="test")
        
        assert result["success"] is True
        assert "data" in result
        assert result["message"] == "执行成功"
    
    async def test_missing_param(self, tool):
        """测试缺少参数"""
        result = await tool.execute()
        
        assert result["success"] is False
        assert "error" in result
    
    async def test_invalid_param(self, tool):
        """测试无效参数"""
        result = await tool.execute(param1=123)  # 应该是字符串
        
        assert result["success"] is False
        assert "参数" in result["error"]
```

## 工具文档规范

每个工具应该有清晰的文档：

```python
class MyTool(BaseTool):
    """
    工具名称
    
    功能描述：
        简要说明工具的功能
    
    使用场景：
        - 场景1
        - 场景2
    
    参数说明：
        - param1 (str): 参数1说明
        - param2 (int, optional): 参数2说明，默认值为 10
    
    返回值：
        返回字典，包含 success, data, message 字段
    
    示例：
        >>> tool = MyTool()
        >>> result = await tool.execute(param1="test")
        >>> print(result)
        {"success": True, "data": {...}, "message": "执行成功"}
    """
    pass
```

