# 日志和调试规范

## 日志记录规范

### 日志级别使用

```python
import logging

logger = logging.getLogger(__name__)

# DEBUG: 详细的调试信息
logger.debug(f"函数参数: param1={param1}, param2={param2}")
logger.debug(f"中间结果: {intermediate_result}")

# INFO: 常规操作信息
logger.info(f"开始处理用户请求 session_id={session_id}")
logger.info(f"用户 {user_id} 登录成功")
logger.info(f"工具 {tool_name} 执行完成，耗时 {elapsed}s")

# WARNING: 警告信息（可能的问题）
logger.warning(f"API 调用超时，将重试 (尝试 {retry_count}/3)")
logger.warning(f"缓存未命中: key={cache_key}")
logger.warning(f"性能警告: 查询耗时 {query_time}s 超过阈值")

# ERROR: 错误信息（已捕获的异常）
logger.error(f"处理失败: {error_msg}", exc_info=True)
logger.error(f"工具 {tool_name} 执行失败: {str(e)}")

# CRITICAL: 严重错误（系统级问题）
logger.critical(f"数据库连接失败: {str(e)}")
logger.critical(f"配置文件损坏: {config_path}")
```

## 日志格式规范

### 基础日志配置

```python
# logger.py
import logging
import sys
from pathlib import Path

def setup_logger(
    name: str,
    level: int = logging.INFO,
    log_file: Path = None
) -> logging.Logger:
    """
    配置日志记录器
    
    Args:
        name: logger 名称
        level: 日志级别
        log_file: 日志文件路径（可选）
        
    Returns:
        配置好的 logger
    """
    logger = logging.getLogger(name)
    logger.setLevel(level)
    
    # 日志格式
    formatter = logging.Formatter(
        fmt='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
        datefmt='%Y-%m-%d %H:%M:%S'
    )
    
    # 控制台处理器
    console_handler = logging.StreamHandler(sys.stdout)
    console_handler.setLevel(level)
    console_handler.setFormatter(formatter)
    logger.addHandler(console_handler)
    
    # 文件处理器（如果指定）
    if log_file:
        file_handler = logging.FileHandler(log_file, encoding='utf-8')
        file_handler.setLevel(level)
        file_handler.setFormatter(formatter)
        logger.addHandler(file_handler)
    
    return logger
```

### 结构化日志

```python
import json
import logging

class StructuredLogger:
    """结构化日志记录器"""
    
    def __init__(self, name: str):
        self.logger = logging.getLogger(name)
    
    def log_event(
        self,
        event_type: str,
        level: str = "INFO",
        **kwargs
    ):
        """
        记录结构化事件
        
        Args:
            event_type: 事件类型
            level: 日志级别
            **kwargs: 事件数据
        """
        log_data = {
            "event_type": event_type,
            "timestamp": datetime.now().isoformat(),
            **kwargs
        }
        
        log_message = json.dumps(log_data, ensure_ascii=False)
        
        if level == "DEBUG":
            self.logger.debug(log_message)
        elif level == "INFO":
            self.logger.info(log_message)
        elif level == "WARNING":
            self.logger.warning(log_message)
        elif level == "ERROR":
            self.logger.error(log_message)

# 使用示例
structured_logger = StructuredLogger(__name__)
structured_logger.log_event(
    "user_action",
    level="INFO",
    user_id=user_id,
    action="login",
    ip_address=ip,
    success=True
)
```

## 上下文日志

### 添加上下文信息

```python
import logging
from contextvars import ContextVar

# 上下文变量
request_id_var: ContextVar[str] = ContextVar('request_id', default='')
session_id_var: ContextVar[str] = ContextVar('session_id', default='')

class ContextFilter(logging.Filter):
    """添加上下文信息到日志"""
    
    def filter(self, record):
        record.request_id = request_id_var.get()
        record.session_id = session_id_var.get()
        return True

# 配置日志
logger = logging.getLogger(__name__)
logger.addFilter(ContextFilter())

# 日志格式包含上下文
formatter = logging.Formatter(
    '%(asctime)s - [%(request_id)s] [%(session_id)s] - '
    '%(name)s - %(levelname)s - %(message)s'
)

# 使用
request_id_var.set("req-123")
session_id_var.set("sess-456")
logger.info("处理用户请求")
# 输出: 2024-01-01 12:00:00 - [req-123] [sess-456] - module - INFO - 处理用户请求
```

## 日志最佳实践

### ✅ 应该做的

```python
# 1. 包含上下文信息
logger.info(f"开始处理任务 task_id={task_id}, user_id={user_id}")

# 2. 使用参数化日志（避免字符串拼接）
logger.debug("用户 %s 执行操作 %s", user_id, action)

# 3. 记录异常堆栈
try:
    risky_operation()
except Exception as e:
    logger.error(f"操作失败: {str(e)}", exc_info=True)

# 4. 记录关键操作的开始和结束
logger.info(f"开始生成 PPT task_id={task_id}")
# ... 执行操作 ...
logger.info(f"PPT 生成完成 task_id={task_id}, 耗时={elapsed}s")

# 5. 记录性能指标
logger.info(f"数据库查询完成，耗时 {query_time:.2f}s，返回 {count} 条记录")
```

### ❌ 不应该做的

```python
# 1. 不要记录敏感信息
logger.info(f"用户登录: password={password}")  # ❌ 泄露密码
logger.info(f"API 调用: api_key={api_key}")    # ❌ 泄露密钥

# 2. 不要在循环中过度记录
for item in large_list:
    logger.debug(f"处理项目: {item}")  # ❌ 可能产生大量日志

# 3. 不要使用 print 代替日志
print("开始处理...")  # ❌ 应使用 logger.info()

# 4. 不要记录未过滤的用户输入
logger.info(f"用户输入: {user_input}")  # ❌ 可能包含恶意内容

# 5. 不要在日志中暴露系统内部结构
logger.error(f"文件路径错误: /usr/local/app/secret/config.py")  # ❌
```

## 调试技巧

### 使用装饰器记录函数调用

```python
import functools
import logging
import time

logger = logging.getLogger(__name__)

def log_function_call(func):
    """记录函数调用的装饰器"""
    @functools.wraps(func)
    async def wrapper(*args, **kwargs):
        logger.debug(f"调用函数 {func.__name__}, args={args}, kwargs={kwargs}")
        start_time = time.time()
        
        try:
            result = await func(*args, **kwargs)
            elapsed = time.time() - start_time
            logger.debug(
                f"函数 {func.__name__} 完成，"
                f"耗时 {elapsed:.3f}s, 返回类型={type(result)}"
            )
            return result
        except Exception as e:
            elapsed = time.time() - start_time
            logger.error(
                f"函数 {func.__name__} 失败，"
                f"耗时 {elapsed:.3f}s, 错误={str(e)}",
                exc_info=True
            )
            raise
    
    return wrapper

# 使用
@log_function_call
async def process_data(data: dict) -> dict:
    # 处理逻辑
    pass
```

### 临时调试日志

```python
# 开发时临时添加详细日志
if __debug__:
    logger.debug(f"临时调试: variable={variable}")
    logger.debug(f"数据结构: {json.dumps(data, indent=2, ensure_ascii=False)}")

# 或使用条件日志
import os

DEBUG_MODE = os.getenv("DEBUG_MODE", "false").lower() == "true"

if DEBUG_MODE:
    logger.debug(f"详细状态: {state}")
```

### 性能分析日志

```python
import time
from contextlib import contextmanager

@contextmanager
def log_execution_time(operation_name: str):
    """记录操作执行时间的上下文管理器"""
    start_time = time.time()
    logger.info(f"开始 {operation_name}")
    
    try:
        yield
    finally:
        elapsed = time.time() - start_time
        logger.info(f"{operation_name} 完成，耗时 {elapsed:.3f}s")

# 使用
with log_execution_time("数据库查询"):
    results = await db.query(...)

with log_execution_time("LLM 生成"):
    response = await llm.generate(...)
```

## 日志审计

### 关键操作审计日志

```python
class AuditLogger:
    """审计日志记录器"""
    
    def __init__(self):
        self.logger = logging.getLogger("audit")
    
    def log_user_action(
        self,
        user_id: str,
        action: str,
        resource: str,
        result: str,
        **metadata
    ):
        """
        记录用户操作
        
        Args:
            user_id: 用户ID
            action: 操作类型
            resource: 资源标识
            result: 操作结果
            **metadata: 额外元数据
        """
        audit_record = {
            "timestamp": datetime.now().isoformat(),
            "user_id": user_id,
            "action": action,
            "resource": resource,
            "result": result,
            **metadata
        }
        
        self.logger.info(json.dumps(audit_record, ensure_ascii=False))

# 使用
audit_logger = AuditLogger()
audit_logger.log_user_action(
    user_id="user-123",
    action="create_ppt",
    resource="ppt-456",
    result="success",
    file_size=1024000,
    slide_count=10
)
```

