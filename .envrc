# direnv 配置文件
# 如果使用 direnv，进入此目录时会自动执行
# 安装 direnv: brew install direnv (macOS) 或 apt install direnv (Linux)
# 然后在 ~/.zshrc 中添加: eval "$(direnv hook zsh)"

# 自动激活 liuy 虚拟环境
if [ -f "$HOME/liuy/bin/activate" ]; then
    source "$HOME/liuy/bin/activate"
elif command -v conda &> /dev/null && conda env list | grep -q "liuy"; then
    conda activate liuy
fi

# 加载环境变量
if [ -f .env ]; then
    export $(cat .env | grep -v '^#' | xargs)
fi

echo "✅ Zenflux Agent 环境已加载"
echo "   虚拟环境: liuy"
echo "   项目目录: $(pwd)"

