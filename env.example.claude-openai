# ==================== 推荐方案 1：Claude + OpenAI Embedding ====================
# 性价比高，质量稳定
# 成本：~$52/月（10k 对话）
# 
# 使用方法：
#   1. 复制此文件为 .env
#   2. 填入真实的 API Keys
#   3. 运行 python test_mem0_setup.py 验证

# Qdrant 向量数据库（腾讯云）
QDRANT_URL=http://172.16.32.30:6333
QDRANT_API_KEY=
MEM0_COLLECTION_NAME=mem0_user_memories

# Embedding: OpenAI（负责向量化）
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-proj-your-openai-key-here
EMBEDDING_MODEL=text-embedding-3-small  # 1536维，$0.02/1M tokens

# LLM: Claude（负责 fact extraction）
MEM0_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-claude-key-here
MEM0_LLM_MODEL=claude-sonnet-4-5-20250929

# Agent 主模型（与 Mem0 共用 Claude API Key）
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# 是否启用 Claude Context Editing（服务端自动清理）
# 可选值：true / false
ENABLE_CONTEXT_EDITING=false

# 其他配置
WORKSPACE_DIR=./workspace
LOG_LEVEL=INFO

