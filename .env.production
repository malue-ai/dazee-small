#Slidespeak
#https://app.slidespeak.co/settings/developer
SLIDESPEAK_API_KEY=d0b6d53a-aba2-4274-b3bc-897b25718a68
# Ragie AI (知识库管理)
# 获取地址: https://docs.ragie.ai/
RAGIE_API_KEY=tnt_ApbM30NCaqe_HcwqgbFj4n569wj4RAZHNJ10vGatBKGow7tUc0aPRBf

