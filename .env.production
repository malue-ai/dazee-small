# CoT Agent MVP 环境变量配置

# Anthropic API密钥 (必填)
# 模型配置 (可选)
# 可选: claude-sonnet-4-5, claude-3-5-sonnet-latest, claude-3-opus-latest
COT_AGENT_MODEL=claude-sonnet-4-5

# 日志级别 (可选)
# 可选: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Tavily MCP Server API (网络搜索功能)
# 获取地址: https://tavily.com/
TAVILY_API_KEY=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

# Exa AI API (代码搜索、深度研究、企业调研)
# 获取地址: https://exa.ai/
