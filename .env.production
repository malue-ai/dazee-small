AWS_S3_BUCKET=dify-storage-zenflux

LLM_DEBUG_VERBOSE=1


# ==================== Mem0 + Qdrant 配置 ====================

# Qdrant 向量数据库配置（腾讯云服务）
# 从腾讯云控制台获取：实例详情 -> 内网地址/外网地址
# 格式：http://172.16.32.30:6333 或 https://gz-vdb-3a69s7xq.sql.tencentcdb.com:8100
QDRANT_URL=http://gz-vdb-3a69s7xg.sql.tencentcdb.com:8100

# Qdrant API Key（如果腾讯云 Qdrant 启用了认证）
# 腾讯云向量数据库控制台 -> 实例详情 -> API密钥
# 如果未启用认证，留空即可
QDRANT_API_KEY=Oe2VLNO3qL7ET65Xb894yh71SqHP3Z5aGDzw01uB

# Mem0 集合名称（Collection Name）
# 用于存储用户记忆向量，建议使用有意义的名称
# 注意：不同环境建议使用不同的集合名（如：dev_memories, prod_memories）
MEM0_COLLECTION_NAME=mem0_prod_memories

# ==================== OpenAI API 配置 ====================

# OpenAI API Key（必需）
# 用于：1) Embedding 向量生成  2) Mem0 内部的 fact extraction
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=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

# Embedding 模型配置
# 推荐：text-embedding-3-small（性价比高，1536维，$0.02/1M tokens）
# 可选：text-embedding-3-large（3072维，精度更高，$0.13/1M tokens）
# 注意：更改模型后需要重建 Qdrant collection（维度不同）
EMBEDDING_MODEL=text-embedding-3-small

# Mem0 内部使用的 LLM 模型（用于从对话中提取记忆）
# 推荐：gpt-4o-mini（快速且便宜，$0.150/1M input tokens）
# 可选：gpt-4o（精度更高，$2.50/1M input tokens）
MEM0_LLM_MODEL=gpt-4o-mini

DIFY_API_KEY=app-AUhGjUpkG34Su4iUAXoUZp0z

COZE_API_KEY=pat_bHCRBoLRb4gXLqPsMv3jum4sTrtM0s6T3mQYjOr9FPKaBIb87XoLcePKJWh75PgR

# Redis 配置（复用 zen0-backend）
REDIS_HOST=zen0-backend-production-redis-rg.w9tdej.ng.0001.apse1.cache.amazonaws.com
REDIS_PORT=6379
# gRPC 服务端口
GRPC_PORT=50051

# gRPC 服务监听地址（0.0.0.0 允许外部访问）
GRPC_HOST=0.0.0.0

# 是否启用 gRPC 服务
ENABLE_GRPC=true
# 修复：使用腾讯云 VectorDB
VECTOR_STORE_PROVIDER=tencent
TENCENT_VDB_URL=http://gz-vdb-3a69s7xg.sql.tencentcdb.com:8100
TENCENT_VDB_USERNAME=root
TENCENT_VDB_API_KEY=Oe2VLNO3qL7ET65Xb894yh71SqHP3Z5aGDzw01uB
TENCENT_VDB_DATABASE=mem0_db

# 修复：Mem0 使用 OpenAI LLM（与模型名匹配）
MEM0_LLM_PROVIDER=openai


