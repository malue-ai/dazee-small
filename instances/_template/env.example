# ============================================================
# 环境变量配置
# ============================================================
#
# 📌 使用说明：
#   1. 复制此文件为 .env：cp env.example .env
#   2. 填入实际的 API 密钥
#   3. .env 文件已在 .gitignore 中，不会提交到代码库
#
# ============================================================

# ==================== 必需配置 ====================

# Anthropic Claude API 密钥
# 获取地址：https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# ==================== 搜索工具密钥（按需配置）====================

# Exa 语义搜索 API 密钥
# 获取地址：https://dashboard.exa.ai/
# EXA_API_KEY=xxx

# Tavily 搜索 API 密钥（web_search 使用）
# 获取地址：https://tavily.com/
# TAVILY_API_KEY=tvly-xxx


# ==================== MCP 工具密钥（按需配置）====================

# Dify 工作流 API 密钥（如果使用 Dify）
# DIFY_API_KEY=app-xxx

# OpenAI API 密钥（如果使用 OpenAI 模型或 Embedding）
# OPENAI_API_KEY=sk-xxx

# SlideSpeak PPT 生成 API 密钥
# 获取地址：https://slidespeak.co/
# SLIDESPEAK_API_KEY=xxx

# PageIndex 长文档分析 API 密钥（deep-doc-reader 使用）
# 获取地址：https://chat.pageindex.ai/chat#settings/api-keys
# 免费额度：1000 页
# PAGEINDEX_API_KEY=pi_xxx

# ==================== Cloud API Skills 密钥（按需配置）====================

# Gemini API（图像生成 - nano-banana-pro）
# 获取地址：https://aistudio.google.com/apikey
# GEMINI_API_KEY=xxx

# Unstructured Partition API（文档解析）
# 获取地址：https://unstructured.io/
# UNSTRUCTURED_API_KEY=xxx
# UNSTRUCTURED_API_URL=https://api.unstructuredapp.io/general/v0/general

# Notion API（笔记与数据库管理）
# 获取地址：https://notion.so/my-integrations
# 创建 Integration 后复制 API Key，并将目标页面分享给该 Integration
# NOTION_API_KEY=ntn_xxx

# Trello API（看板任务管理）
# 获取地址：https://trello.com/app-key
# TRELLO_API_KEY=xxx
# TRELLO_TOKEN=xxx

# Google Places API（周边地点搜索）
# 获取地址：https://console.cloud.google.com/ → 启用 Places API (New)
# GOOGLE_PLACES_API_KEY=xxx

# Discord Bot Token（消息与频道管理）
# 获取地址：https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=xxx

# ==================== 可选配置 ====================

# 日志级别：DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO

# 环境标识：development / production
# APP_ENV=development
