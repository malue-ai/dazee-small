# ============================================================
# 实例环境变量模板
# ============================================================
#
# 使用方式：
#   1. 复制此文件为 .env：cp env.example .env
#   2. 填入必填的 API Key
#   3. 完整变量说明可参考 instances/xiaodazi/.env.example
#

# ==================== 必填 ====================

# Anthropic API Key（主 Agent 对话模型）
ANTHROPIC_API_KEY=

# 通义千问 API Key（框架内部 LLM 调用）
DASHSCOPE_API_KEY=

# OpenAI API Key（Embedding + Mem0）
OPENAI_API_KEY=

# ==================== 可选 · 云端协同 ====================
# 不设置 CLOUD_URL 则不会初始化云端客户端，云端 Skill 不可用

# 云端 Agent 服务地址（不设则跳过云端初始化）
# CLOUD_URL=https://your-cloud-agent.example.com

# 云端登录凭据（可选；不填则仅使用本地 JWT 透传等）
# CLOUD_USERNAME=your_username
# CLOUD_PASSWORD=your_password

# ==================== 其他可选 ====================
# LOG_LEVEL=INFO
# QDRANT_URL=http://localhost:6333
# REDIS_HOST=localhost
# REDIS_PORT=6379
